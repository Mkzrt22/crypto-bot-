# ── CEX (Binance / optional) ──────────────────────────────────────────────────
API_KEY=
API_SECRET=
SANDBOX=true

# ── Solana Wallet ─────────────────────────────────────────────────────────────
# Set SOLANA_ENABLED=true to activate on-chain trading via Jupiter DEX
SOLANA_ENABLED=false

# Your wallet private key as a base58 string.
# Generate one with: python -c "from solders.keypair import Keypair; k=Keypair(); print(k.to_base58_string())"
# WARNING: keep this file secret — never commit it to git!
SOLANA_PRIVATE_KEY=

# RPC endpoint — free public node or your own (Helius, QuickNode, etc.)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

